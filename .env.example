# LM Studio / OpenAI-compatible local server
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=dolphin-3.0-llama-3.1-8b
# Optional: separate model for programming/code/debug prompts
LMSTUDIO_CODING_BASE_URL=http://localhost:1234/v1
LMSTUDIO_CODING_MODEL=dolphin-3.0-llama-3.1-8b
LLM_PROGRAMMING_ROUTER_ENABLED=true
LMSTUDIO_TIMEOUT=120
LLM_MAX_CONTEXT_CHARS=18000
LLM_MAX_OUTPUT_TOKENS=900
LLM_TEMPERATURE=0.45
LLM_TOP_P=0.90
LLM_REPEAT_PENALTY=1.10
LLM_TOP_K=40
LLM_MIN_P=0.05

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_USERNAMES=
TELEGRAM_OWNER_IDS=
TELEGRAM_ALLOW_ALL=true
TELEGRAM_AUTO_START=false

# Internet / learning
INTERNET_ENABLED=true
WEB_USER_AGENT=M0N4C0-AI/1.0 local research bot
DEFAULT_LEARN_ROUNDS=10
MAX_LEARN_ROUNDS=10
MAX_PAGES_PER_ROUND=8

# Database
MONACO_DB_PATH=data/monaco_memory.db

# Website browser sessions
PLAYWRIGHT_USER_DATA_DIR=data/website_sessions

# Technical status messages
TECH_STATUS=normal
